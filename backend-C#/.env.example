# ============================================
# 数据库配置
# ============================================

# 数据库类型: sqlite | mysql | postgresql | sqlserver
DB_PROVIDER=sqlite

# ============================================
# SQLite 配置 (本地开发)
# ============================================
# DB_PATH=ims.db

# ============================================
# MySQL 配置
# ============================================
# DB_PROVIDER=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=ims
# DB_USER=ims
# DB_PASSWORD=your_secure_password
# DB_SSLMODE=None

# ============================================
# PostgreSQL 配置
# ============================================
# DB_PROVIDER=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=ims
# DB_USER=postgres
# DB_PASSWORD=your_secure_password

# ============================================
# SQL Server 配置
# ============================================
# DB_PROVIDER=sqlserver
# DB_HOST=localhost
# DB_NAME=ims
# DB_USER=sa
# DB_PASSWORD=your_secure_password

# ============================================
# JWT 配置 (生产环境务必修改)
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ============================================
# 服务器配置
# ============================================
SERVER_PORT=3001
SERVER_MODE=production
