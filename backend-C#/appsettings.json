{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Server": {
    "Port": 3001,
    "Mode": "development",
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000",
      "http://127.0.0.1:5173"
    ]
  },
  "JWT": {
    "Secret": "your-super-secret-jwt-key-change-in-production",
    "Expiration": "24h"
  },
  "Database": {
    "Provider": "sqlite",
    "MySQL": {
      "Host": "${DB_HOST}",
      "Port": "${DB_PORT}",
      "Database": "${DB_NAME}",
      "User": "${DB_USER}",
      "Password": "${DB_PASSWORD}",
      "SslMode": "${DB_SSLMODE}"
    },
    "PostgreSQL": {
      "Host": "${DB_HOST}",
      "Port": "${DB_PORT}",
      "Database": "${DB_NAME}",
      "User": "${DB_USER}",
      "Password": "${DB_PASSWORD}"
    },
    "SQLServer": {
      "Host": "${DB_HOST}",
      "Database": "${DB_NAME}",
      "User": "${DB_USER}",
      "Password": "${DB_PASSWORD}",
      "TrustServerCertificate": true
    },
    "SQLite": {
      "Path": "ims.db"
    }
  },
  "RateLimit": {
    "Enabled": true,
    "RequestsPerMinute": 60,
    "Burst": 10
  },
  "Admin": {
    "DefaultUsername": "admin",
    "DefaultPassword": "admin123",
    "DefaultEmail": "admin@ims.com"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
