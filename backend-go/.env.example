# 服务器配置
IMS_SERVER_PORT=3001
IMS_SERVER_MODE=development

# 数据库配置
IMS_DATABASE_DRIVER=mysql
IMS_DATABASE_HOST=localhost
IMS_DATABASE_PORT=3306
IMS_DATABASE_NAME=ims_db
IMS_DATABASE_USER=root
IMS_DATABASE_PASSWORD=

# SQLite配置（当driver为sqlite时使用）
IMS_SQLITE_PATH=./data/ims.db

# JWT配置
IMS_JWT_SECRET=your-secret-key-change-in-production
IMS_JWT_EXPIRATION=24h

# 日志配置
IMS_LOG_LEVEL=info
IMS_LOG_FILENAME=./logs/app.log

# 限流配置
IMS_RATE_LIMIT_ENABLED=true
IMS_RATE_LIMIT_REQUESTS_PER_MINUTE=60
IMS_RATE_LIMIT_BURST=10

# 默认管理员配置
IMS_ADMIN_DEFAULT_USERNAME=admin
IMS_ADMIN_DEFAULT_PASSWORD=admin123
IMS_ADMIN_DEFAULT_EMAIL=admin@example.com
