{
  "name": "ims-vue",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "start": "node start-dev.js",
    "dev": "node start-dev.js",
    "dev:frontend": "node start-dev.js --frontend-only",
    "dev:backend": "node start-dev.js --backend-only",
    "frontend:dev": "cd frontend-vue3-vite && npm run dev",
    "frontend:build": "cd frontend-vue3-vite && npm run build",
    "frontend:preview": "cd frontend-vue3-vite && npm run preview",
    "backend:dev": "cd backend-JS && npm run dev",
    "backend:start": "cd backend-JS && npm start",
    "backend:build": "cd backend-JS && echo 'Node.js backend does not require build'",
    "build": "cd frontend-vue3-vite && npm run build",
    "install:all": "npm install && cd frontend-vue3-vite && npm install",
    "clean": "rimraf frontend-vue3-vite/node_modules node_modules"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "rimraf": "^5.0.10"
  }
}
